{
  "name": "@sonarmd/ui",
  "version": "0.1.0",
  "description": "SonarMD design system — reusable React component library",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.umd.cjs"
      }
    },
    "./tokens": {
      "import": {
        "types": "./dist/sonarmd-tokens.d.ts",
        "default": "./dist/sonarmd-tokens.js"
      },
      "require": {
        "types": "./dist/sonarmd-tokens.d.ts",
        "default": "./dist/sonarmd-tokens.umd.cjs"
      }
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "dependencies": {
    "@types/react-window": "^1.8.8",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "keywords": [
    "sonarmd",
    "design-system",
    "react",
    "components",
    "ui"
  ],
  "license": "UNLICENSED"
}
